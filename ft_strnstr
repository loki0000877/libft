char  *ft_strnstr(const char *big, const char *little, size_t len)
{
  unsigned int  i;
  unsigned int  j;

  i = 0;
  if (little[0] == '\0')
    return (char *)big;
  while (big[i] && i < len)
  {
    j = 0;
    while (i + j < len && little[j] && big[i + j] && big[i + j] == little[j])
    {
      j++;
      if (little[j] == '\0')
        return (char *)&big[i];
    }
    i++;
  }
  return NULL;
}
