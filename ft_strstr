char  *ft_strstr(const char *big, const char *little)
{
  unsigned int  i;
  unsigned int  j;

  i = 0;
  if (little[0] == '\0')
    return (char *)big;
  while (big[i])
  {
    j = 0;
    while (big[i + j] && (big[i + j] == little[j]))
    {
      j++;
      if (little[j] == '\0' )
        return (char *)&big[i];
    }
    i++;
  }
  return NULL;
}
